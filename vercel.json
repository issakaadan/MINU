{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "fluid": true,
  "buildCommand": "python scripts/build_player_rag_index.py && python scripts/bundle_players_seed.py && python scripts/bundle_players_catalog_db.py && cd frontend && npm ci && npm run build",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.py"
    }
  ],
  "functions": {
    "api/index.py": {
      "maxDuration": 60,
      "includeFiles": "backend/data/**",
      "excludeFiles": "{frontend/node_modules/**,frontend/src/**,frontend/public/**,**/__pycache__/**,**/*.pyc,**/*.pyo,.git/**,.github/**}"
    }
  }
}
