# Optional backend settings for local development.
# Copy this file to backend/.env only if you need to override defaults.

APP_NAME=من اللاعب | Football Edition
API_PREFIX=/api
ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:4173,http://localhost:4173

# Optional fixed login overrides for deployed environments.
# Leave these empty for local auto-generated Minu credentials.
# MINU_ADMIN_USERNAME=minu-admin
# MINU_ADMIN_PASSWORD=
# MINU_ADMIN_PASSWORD_HASH=
# MINU_SESSION_SECRET=
# MINU_SESSION_HOURS=24
# MINU_CARD_LINK_HOURS=168
# MINU_SESSION_COOKIE=minu_session

# Optional override for local runtime storage.
# Leave commented out to use the default per-user local directory.
# Windows example:
# LOCAL_RUNTIME_DIR=C:/Users/your-user/AppData/Local/WhoIsThePlayerFootball
